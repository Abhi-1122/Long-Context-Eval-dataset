--- a/libs/core/tests/unit_tests/runnables/test_runnable.py
+++ b/libs/core/tests/unit_tests/runnables/test_runnable.py
@@ -1,3 +1,4 @@
+import pytest, asyncio
+from langchain_core.runnables import RunnableParallel, RunnableLambda
+
+def test_runnable_parallel_propagates_exceptions():
+    def fail(_): raise ValueError("branch failure")
+    chain = RunnableParallel(
+        good=RunnableLambda(lambda x: x.upper()),
+        bad=RunnableLambda(fail),
+    )
+    with pytest.raises(ValueError, match="branch failure"):
+        chain.invoke("hello")
+
+@pytest.mark.asyncio
+async def test_runnable_parallel_async_propagates_exceptions():
+    async def afail(_): raise RuntimeError("async branch failure")
+    chain = RunnableParallel(
+        good=RunnableLambda(lambda x: x),
+        bad=RunnableLambda(afail),
+    )
+    with pytest.raises(RuntimeError, match="async branch failure"):
+        await chain.ainvoke("hello")
+
--- a/libs/core/tests/unit_tests/callbacks/test_callback_manager.py
+++ b/libs/core/tests/unit_tests/callbacks/test_callback_manager.py
@@ -1,3 +1,4 @@
+def test_error_event_fired_on_parallel_exception():
+    from langchain_core.runnables import RunnableParallel, RunnableLambda
+    from langchain_core.callbacks import BaseCallbackHandler
+
+    class ErrorCapture(BaseCallbackHandler):
+        def __init__(self): self.errors = []
+        def on_chain_error(self, error, **kwargs): self.errors.append(error)
+
+    handler = ErrorCapture()
+    chain = RunnableParallel(bad=RunnableLambda(lambda _: 1/0))
+    with pytest.raises(ZeroDivisionError):
+        chain.invoke("x", config={"callbacks": [handler]})
+    assert len(handler.errors) == 1, "on_chain_error must fire for failed branch"
