--- a/tests/test_helpers.py
+++ b/tests/test_helpers.py
@@ -1,4 +1,4 @@
 import pytest
 from flask import Flask, send_file
+import os, tempfile
 
+def test_send_file_max_age_with_conditional(app):
+    """max_age must be respected even when conditional=True."""
+    with tempfile.NamedTemporaryFile(suffix=".txt", delete=False) as f:
+        f.write(b"hello")
+        tmp_path = f.name
+    with app.test_request_context("/"):
+        response = send_file(tmp_path, conditional=True, max_age=3600)
+        cc = response.headers.get("Cache-Control", "")
+        assert "max-age=3600" in cc, (
+            f"Expected max-age=3600 in Cache-Control, got: {cc!r}"
+        )
+    os.unlink(tmp_path)
