--- a/tests/test_response_model_as_return_annotation.py
+++ b/tests/test_response_model_as_return_annotation.py
@@ -1,3 +1,4 @@
+from typing import Union, Literal, Annotated
+from pydantic import BaseModel, Field
+from fastapi import FastAPI
+from fastapi.testclient import TestClient
+
+class Cat(BaseModel):
+    type: Literal["cat"]
+    meow: str
+    indoor: bool = False
+
+class Dog(BaseModel):
+    type: Literal["dog"]
+    bark: str
+    trained: bool = False
+
+Animal = Annotated[Union[Cat, Dog], Field(discriminator="type")]
+
+def build_app_v2():
+    app = FastAPI()
+    @app.get("/animal", response_model=Animal)
+    def get_animal():
+        return Cat(type="cat", meow="mrrr")
+    return app
+
+def test_exclude_unset_with_union_discriminator_pydantic_v2():
+    client = TestClient(build_app_v2())
+    resp = client.get("/animal")
+    data = resp.json()
+    assert "indoor" not in data, (
+        f"Unset field 'indoor' leaked into response: {data}"
+    )
+    assert data == {"type": "cat", "meow": "mrrr"}
+
+def test_exclude_unset_with_union_discriminator_pydantic_v1():
+    """Same scenario but forcing pydantic v1 compat path."""
+    # Uses model_dump(exclude_unset=True) path in _compat.py
+    cat = Cat(type="cat", meow="mrrr")
+    from fastapi._compat import _model_dump
+    dumped = _model_dump(cat, exclude_unset=True)
+    assert "indoor" not in dumped, (
+        f"Compat layer leaked unset field: {dumped}"
+    )
